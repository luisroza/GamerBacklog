@page "/backlog"
@inject IGameBacklogService BacklogService
@rendermode InteractiveServer

<PageTitle>Backlog</PageTitle>
<section class="page-heading"><div><p class="eyebrow">Backlog assistant</p><h1>Turn the pile into a small, playable shortlist.</h1></div></section>
<section class="panel picker-panel"><div><h2>Pick what fits tonight</h2><p>Use time, mood, and platform to choose from games you already own or paused.</p></div><div class="picker-controls"><label>Mood<select @bind="mood"><option>Any</option><option>short</option><option>cozy</option><option>story</option><option>challenge</option><option>night</option></select></label><label>Hours available<input type="number" min="1" max="120" @bind="availableHours" /></label><label>Platform<select @bind="platform"><option>Any</option>@foreach (var candidate in Platforms) { <option>@candidate</option> }</select></label></div></section>
<section class="card-grid">@foreach (var game in Picks) { <article class="game-card recommendation"><div class="cover large @game.CoverGradient"></div><div><span class="status backlog">@game.StatusLabel</span><h2>@game.Title</h2><p>@game.Note</p><dl class="facts"><div><dt>Platform</dt><dd>@game.Platform</dd></div><div><dt>Remaining</dt><dd>@Math.Max(game.EstimatedHours - game.PlayedHours, 0) h</dd></div><div><dt>Priority</dt><dd>@(game.Priority == 0 ? "None" : game.Priority)</dd></div></dl></div></article> }</section>
<section class="panel"><h2>Priority backlog</h2><div class="stack">@foreach (var game in BacklogService.GetPriorityBacklog()) { <article class="game-row"><div class="cover @game.CoverGradient"></div><div class="game-main"><strong>@game.Title</strong><span>@game.Platform - @game.EstimatedHours h - @game.StatusLabel</span></div><div class="priority-pill">P@(game.Priority == 0 ? "-" : game.Priority)</div></article> }</div></section>
@code { private string mood = "Any"; private int availableHours = 12; private string platform = "Any"; private IReadOnlyList<string> Platforms => BacklogService.GetGames().Select(game => game.Platform).Distinct().Order().ToList(); private IReadOnlyList<GameEntry> Picks => BacklogService.PickNextGames(new NextGameCriteria(mood, availableHours, platform)); }
