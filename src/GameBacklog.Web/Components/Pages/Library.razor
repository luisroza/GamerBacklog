@page "/library"
@inject IGameBacklogService BacklogService
@inject IGameMetadataProvider MetadataProvider
@inject IEnumerable<IGameCatalogProvider> CatalogProviders
@inject IEnumerable<IExternalGameLibraryProvider> LibraryProviders
@inject IAccountSessionService AccountSession
@rendermode InteractiveServer

<PageTitle>Library</PageTitle>
<section class="page-heading"><div><p class="eyebrow">Library</p><h1>Search, filter, and update the collection.</h1></div></section>
<section class="panel import-panel"><div><p class="eyebrow">Game catalog search</p><h2>Search Steam and PlayStation 5</h2><p>Search Valve Steam apps, or search PlayStation 5 catalog matches through the configured metadata provider.</p></div><div class="import-controls"><label>Catalog<select @bind="selectedCatalogSource">@foreach (var provider in CatalogProviders) { <option value="@provider.SourceName">@provider.SourceName</option> }</select></label><label>Game search<input @bind="catalogQuery" @bind:event="oninput" placeholder="Try Elden, Hades, God of War, Balatro" /></label><label>Add as<select @bind="catalogStatus"><option value="@GameStatus.WantToPlay">Want to Play</option><option value="@GameStatus.Playing">Playing</option><option value="@GameStatus.Wishlist">Wishlist</option></select></label></div><div class="provider-actions"><button class="primary" type="button" @onclick="SearchCatalogAsync" disabled="@isCatalogSearching">@(isCatalogSearching ? "Searching..." : "Search selected catalog")</button><button type="button" @onclick="SearchMetadataAsync" disabled="@isSearching">@(isSearching ? "Searching..." : "Search metadata provider")</button></div>@if (!string.IsNullOrWhiteSpace(importMessage)) { <p class="notice">@importMessage</p> }@if (catalogResults.Count > 0) { <div class="metadata-results">@foreach (var result in catalogResults) { <article class="metadata-result"><div><strong>@result.Title</strong><span>@result.Provider @GetYear(result) - @string.Join(", ", result.Platforms.Take(3))</span><p>@result.Summary</p></div><button type="button" @onclick="() => AddCatalogResult(result)">Add</button></article> }</div> } else if (metadataResults.Count > 0) { <div class="metadata-results">@foreach (var result in metadataResults) { <article class="metadata-result"><div><strong>@result.Title</strong><span>@result.Provider @GetYear(result) - @string.Join(", ", result.Platforms.Take(3))</span><p>@result.Summary</p></div><button type="button" @onclick="() => AddMetadataResult(result)">Add</button></article> }</div> }</section>
<section class="panel import-panel"><div><p class="eyebrow">Played game imports</p><h2>Steam first, PlayStation manual-safe</h2><p>Steam can be implemented with official owned/recently-played endpoints. PlayStation has no safe public library API, so this app keeps it as a manual/import placeholder.</p></div><div class="provider-actions">@foreach (var provider in LibraryProviders) { <button type="button" @onclick="() => ImportPlayedGamesAsync(provider)">Import @provider.Name sample</button> }</div></section>
<section class="panel import-panel"><div><p class="eyebrow">Your game list</p><h2>Add a game manually</h2>@if (AccountSession.IsAuthenticated) { <p>Add games you want to play, games you are playing, games played, and their statuses.</p> } else { <p><a href="account">Login or create an account</a> before adding personal games.</p> }</div><div class="manual-game-form"><label>Title<input @bind="manualTitle" disabled="@(!AccountSession.IsAuthenticated)" /></label><label>Platform<input @bind="manualPlatform" disabled="@(!AccountSession.IsAuthenticated)" /></label><label>Status<select @bind="manualStatus" disabled="@(!AccountSession.IsAuthenticated)">@foreach (var status in Enum.GetValues<GameStatus>()) { <option value="@status">@GetStatusLabel(status)</option> }</select></label><label>Ownership<select @bind="manualOwnership" disabled="@(!AccountSession.IsAuthenticated)">@foreach (var ownership in Enum.GetValues<OwnershipType>()) { <option value="@ownership">@ownership</option> }</select></label><label>Estimated hours<input type="number" min="1" max="500" @bind="manualEstimatedHours" disabled="@(!AccountSession.IsAuthenticated)" /></label><label>Notes<input @bind="manualNotes" disabled="@(!AccountSession.IsAuthenticated)" /></label><button class="primary" type="button" @onclick="AddManualGame" disabled="@(!CanAddManualGame)">Add to my list</button></div></section>
<section class="toolbar"><label>Search<input @bind="search" @bind:event="oninput" placeholder="Title, genre, tag, platform" /></label><label>Status<select @bind="selectedStatus"><option value="">All statuses</option>@foreach (var status in Enum.GetValues<GameStatus>()) { <option value="@status">@GetStatusLabel(status)</option> }</select></label><label>Platform<select @bind="selectedPlatform"><option>All</option>@foreach (var platform in Platforms) { <option>@platform</option> }</select></label><span class="result-count">@FilteredGames.Count games</span></section>
<section class="library-shell"><aside class="filter-panel"><h2>Fast views</h2><button type="button" @onclick="() => selectedStatus = GameStatus.Playing">Currently playing</button><button type="button" @onclick="() => selectedStatus = GameStatus.WantToPlay">Backlog only</button><button type="button" @onclick="() => selectedStatus = GameStatus.Completed">Completed</button><button type="button" @onclick="ClearFilters">Clear filters</button></aside><div class="library-list">@foreach (var game in FilteredGames) { <article class="game-row library-item"><div class="cover @game.CoverGradient"></div><div class="game-main"><strong>@game.Title</strong><span>@game.Platform - @game.OwnershipLabel - @game.EstimatedHours h estimate</span></div><select class="status-select" value="@game.Status" @onchange="e => UpdateStatus(game.Id, e.Value?.ToString())">@foreach (var status in Enum.GetValues<GameStatus>()) { <option value="@status">@GetStatusLabel(status)</option> }</select><span class="rating">@(game.Rating > 0 ? $"{game.Rating:0.0}" : "Not rated")</span></article> }</div></section>
@code { private string? search; private string? catalogQuery; private string? importMessage; private string manualTitle = string.Empty; private string manualPlatform = "PC"; private string manualNotes = string.Empty; private bool isSearching; private bool isCatalogSearching; private GameStatus? selectedStatus; private string selectedPlatform = "All"; private string? selectedCatalogSource; private GameStatus metadataStatus = GameStatus.WantToPlay; private GameStatus catalogStatus = GameStatus.WantToPlay; private GameStatus manualStatus = GameStatus.WantToPlay; private OwnershipType manualOwnership = OwnershipType.Digital; private int manualEstimatedHours = 10; private IReadOnlyList<GameMetadataSearchResult> metadataResults = []; private IReadOnlyList<GameMetadataSearchResult> catalogResults = []; private bool CanAddManualGame => AccountSession.IsAuthenticated && !string.IsNullOrWhiteSpace(manualTitle) && !string.IsNullOrWhiteSpace(manualPlatform); private IReadOnlyList<string> Platforms => BacklogService.GetGames().Select(g => g.Platform).Distinct().Order().ToList(); private IReadOnlyList<GameEntry> FilteredGames => BacklogService.SearchGames(search, selectedStatus, selectedPlatform); protected override void OnInitialized() => selectedCatalogSource = CatalogProviders.FirstOrDefault()?.SourceName; private void UpdateStatus(int gameId, string? value) { if (Enum.TryParse<GameStatus>(value, out var status)) BacklogService.UpdateStatus(gameId, status); } private void ClearFilters() { search = null; selectedStatus = null; selectedPlatform = "All"; } private async Task SearchMetadataAsync() { isSearching = true; importMessage = null; catalogResults = []; try { metadataResults = await MetadataProvider.SearchAsync(catalogQuery ?? string.Empty); if (metadataResults.Count == 0) importMessage = "No games found from the configured metadata provider."; } finally { isSearching = false; } } private async Task SearchCatalogAsync() { isCatalogSearching = true; importMessage = null; metadataResults = []; try { var provider = CatalogProviders.FirstOrDefault(p => p.SourceName == selectedCatalogSource) ?? CatalogProviders.First(); catalogResults = await provider.SearchAsync(catalogQuery ?? string.Empty); if (catalogResults.Count == 0) importMessage = $"No games found from {provider.SourceName}."; } finally { isCatalogSearching = false; } } private void AddMetadataResult(GameMetadataSearchResult result) { var platform = result.Platforms.FirstOrDefault() ?? "Unknown"; var added = BacklogService.AddFromMetadata(result, platform, metadataStatus); importMessage = $"{added.Title} was added to the library as {added.StatusLabel}."; search = added.Title; } private void AddCatalogResult(GameMetadataSearchResult result) { var platform = result.Provider.Contains("Steam", StringComparison.OrdinalIgnoreCase) ? "Steam" : "PlayStation 5"; var added = BacklogService.AddFromMetadata(result, platform, catalogStatus); importMessage = $"{added.Title} was added from {result.Provider} as {added.StatusLabel}."; search = added.Title; } private async Task ImportPlayedGamesAsync(IExternalGameLibraryProvider provider) { var games = await provider.GetPlayedGamesAsync("demo-user"); var imported = BacklogService.ImportPlayedGames(games); importMessage = imported == 0 ? $"{provider.Name} sample was already represented in the library." : $"Imported {imported} played games from {provider.Name}."; selectedStatus = GameStatus.Playing; } private void AddManualGame() { if (!CanAddManualGame) { importMessage = "Login and enter a title/platform before adding a game."; return; } var added = BacklogService.AddManualGame(new ManualGameRequest(manualTitle, manualPlatform, manualStatus, manualOwnership, manualEstimatedHours, manualNotes)); importMessage = $"{added.Title} was added to your list as {added.StatusLabel}."; search = added.Title; manualTitle = string.Empty; manualNotes = string.Empty; manualEstimatedHours = 10; } private static string GetStatusLabel(GameStatus status) => status == GameStatus.WantToPlay ? "Want to Play" : status.ToString(); private static string GetYear(GameMetadataSearchResult result) => result.ReleaseYear is null ? string.Empty : $"({result.ReleaseYear})"; }
