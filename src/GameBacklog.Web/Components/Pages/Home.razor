@page "/"
@inject IGameBacklogService BacklogService
@rendermode InteractiveServer

<PageTitle>GameBacklog Dashboard</PageTitle>
@{ var stats = BacklogService.GetStats(); var playing = BacklogService.GetGames().Where(game => game.Status == GameStatus.Playing).ToList(); var priority = BacklogService.GetPriorityBacklog().Take(4).ToList(); var quickPicks = BacklogService.PickNextGames(new NextGameCriteria("Any", 12, "Any")); }
<section class="hero-panel"><div><p class="eyebrow">Personal game library</p><h1>Choose tonight's game without wrestling the whole backlog.</h1><p class="lede">Track ownership, progress, mood, priority, and completion in one focused Blazor workspace.</p></div><div class="hero-actions"><a class="button primary" href="library">Open library</a><a class="button" href="backlog">Pick next</a></div></section>
<section class="metric-grid"><div class="metric"><span>Total games</span><strong>@stats.TotalGames</strong></div><div class="metric"><span>Playing</span><strong>@stats.Playing</strong></div><div class="metric"><span>Backlog</span><strong>@stats.Backlog</strong></div><div class="metric"><span>Left to play</span><strong>@stats.EstimatedBacklogHours h</strong></div></section>
<div class="dashboard-grid"><section class="panel"><h2>Continue where it matters</h2><div class="stack">@foreach (var game in playing) { <article class="game-row"><div class="cover @game.CoverGradient"></div><div class="game-main"><strong>@game.Title</strong><span>@game.Platform - @game.PlayedHours h played</span></div><span class="status playing">@game.StatusLabel</span></article> }</div></section><section class="panel"><h2>Priority shortlist</h2><div class="stack">@foreach (var game in priority) { <article class="game-row"><div class="cover @game.CoverGradient"></div><div class="game-main"><strong>@game.Title</strong><span>@game.Platform - @game.EstimatedHours h</span></div><span class="status backlog">@game.StatusLabel</span></article> }</div></section></div>
<section class="panel"><h2>Playable in the next 12 hours</h2><div class="card-grid">@foreach (var game in quickPicks) { <article class="game-card"><div class="cover large @game.CoverGradient"></div><span class="status backlog">@game.StatusLabel</span><h3>@game.Title</h3><p>@game.Note</p></article> }</div></section>
